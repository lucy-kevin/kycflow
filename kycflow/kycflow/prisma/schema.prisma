generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Business {
  id            String         @id @default(uuid())
  name          String
  email         String         @unique
  password      String
  createdAt     DateTime       @default(now())
  verifications Verification[]
}

model Verification {
  id              String    @id @default(uuid())
  businessId      String
  business        Business  @relation(fields: [businessId], references: [id])
  customerName    String
  dateOfBirth     DateTime
  nationality     String
  email           String
  idType          String
  documentUrl     String
  status          String    @default("pending")
  confidenceScore Int       @default(0)
  checkResults    Json
  reviewerNote    String?
  submittedAt     DateTime  @default(now())
  reviewedAt      DateTime?
}